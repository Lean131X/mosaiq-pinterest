# Copia este archivo a ".env" (el .env real NO se sube a GitHub).

# Secreto para firmar los tokens de sesion
SECRETO=cambia_esto_por_algo_largo_y_secreto

# Origenes permitidos para CORS (separados por coma)
ORIGENES_PERMITIDOS=http://127.0.0.1:5500,http://localhost:5500

# --- Amazon S3 (se llena en el componente Cloud) ---
AWS_REGION=us-east-1
AWS_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=